default_platform(:ios)

# --- Paths -------------------------------------------------------------------
# Fastlane runs from ./fastlane, so xcodegen + xcodebuild need to chdir up one.
REPO_ROOT = File.expand_path("..", __dir__)

platform :ios do
  before_all do
    setup_ci if is_ci
  end

  desc "Run the unit test suite (mirrors .github/workflows/ci.yml)"
  lane :test do
    regenerate_project
    run_tests(
      project: "Harvest.xcodeproj",
      scheme: "Harvest",
      configuration: "Debug",
      result_bundle: true
    )
  end

  desc "Fetch signing certs locally via match. Generates on first run if missing; fetches on subsequent runs."
  lane :certs do
    match(type: "appstore", readonly: false, api_key: load_api_key)
  end

  desc "Archive Release and upload to TestFlight"
  lane :beta do
    api_key = load_api_key

    regenerate_project

    match(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key
    )

    # ASC returns the most recent build; +1 or 1 on first-ever upload.
    current = latest_testflight_build_number(
      app_identifier: "io.bitrat.harvest",
      initial_build_number: 0,
      api_key: api_key
    )
    next_build = current + 1
    UI.message("Uploading as build #{next_build} (latest on ASC: #{current})")

    build_app(
      project: "Harvest.xcodeproj",
      scheme: "Harvest",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{next_build}",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "io.bitrat.harvest",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  # --- Helpers ---------------------------------------------------------------

  def regenerate_project
    Dir.chdir(REPO_ROOT) { sh("xcodegen generate") }
  end

  # key_filepath only — the key_content + is_key_content_base64 path trips
  # "invalid curve name" in OpenSSL 3 on macos-latest runners. CI materializes
  # the .p8 from APP_STORE_CONNECT_API_KEY_BASE64 before invoking fastlane.
  def load_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: File.expand_path("~/.fastlane/harvest/asc_api_key.p8")
    )
  end
end
