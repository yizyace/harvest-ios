// Debug build configuration.
// Base URL defaults to production per handoff §3 — the iOS simulator/device is
// not on the Rails monolith owner's dev-CA machine, so dev builds can't reach
// harvest.bitrat.test without per-device trust configuration. Override locally
// in a gitignored Secrets.xcconfig if you've set that up.

API_BASE_URL = https:/$()/harvest.bitrat.io

SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_COMPILATION_MODE = singlefile
GCC_OPTIMIZATION_LEVEL = 0
ONLY_ACTIVE_ARCH = YES
ENABLE_TESTABILITY = YES
DEBUG_INFORMATION_FORMAT = dwarf
